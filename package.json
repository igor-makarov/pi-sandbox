{
  "name": "@igormaka/pi-sandbox",
  "version": "0.0.1",
  "description": "A proper sandbox extension for pi, using the Anthropic Sandbox Runtime",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "main": "src/index.ts",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build'",
    "check": "tsc --noEmit",
    "format": "prettier --write --list-different .",
    "format:check": "prettier --check .",
    "test": "vitest --run"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.49",
    "deepmerge": "^4.3.1",
    "picomatch": "^4.0.3",
    "shell-quote": "^1.8.3"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@mariozechner/pi-tui": "^0.65.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.0.9",
    "@types/picomatch": "^4.0.2",
    "@types/shell-quote": "^1.7.5",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
